<?xml version="1.0" ?>
<sdf version="1.6">
  <model name="camera_robot">
    <!-- ==================== 底盘 ==================== -->
    <link name="base_link">
      <pose>0 0 0.13 0 0 0</pose>

      <inertial>
        <mass>8.0</mass>
        <inertia>
          <ixx>0.15</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.20</iyy><iyz>0</iyz>
          <izz>0.25</izz>
        </inertia>
      </inertial>

      <collision name="collision">
        <geometry>
          <box><size>0.6 0.35 0.15</size></box>
        </geometry>
      </collision>

      <visual name="visual">
        <geometry>
          <box><size>0.6 0.35 0.15</size></box>
        </geometry>
        <material>
          <ambient>0.8 0.2 0.2 1</ambient>
          <diffuse>0.8 0.2 0.2 1</diffuse>
          <specular>0.1 0.1 0.1 1</specular>
        </material>
      </visual>
    </link>

    <!-- ==================== 四个车轮 ==================== -->
    <!--
      轮子布局（俯视）：
        前左(FL)  前右(FR)
        后左(RL)  后右(RR)
      轮子绕 Y 轴旋转 → pose 旋转 (0 1.5708 0)
      轮子中心相对 base_link 偏移：
        X: ±0.2 m（前/后）
        Y: ±0.19 m（左/右）
        Z: -0.055 m（悬挂在底盘下方，使轮子刚好落地）
    -->

    <!-- 前左轮 (FL) -->
    <link name="front_left_wheel">
      <pose>0.2 0.205 0.075 1.5708 0 0</pose>
      <inertial>
        <mass>0.8</mass>
        <inertia>
          <ixx>0.012</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.012</iyy><iyz>0</iyz>
          <izz>0.02</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <cylinder><radius>0.075</radius><length>0.06</length></cylinder>
        </geometry>
        <surface>
          <friction>
            <ode><mu>1.0</mu><mu2>1.0</mu2></ode>
          </friction>
        </surface>
      </collision>
      <visual name="visual">
        <geometry>
          <cylinder><radius>0.075</radius><length>0.06</length></cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.15 0.15 0.15 1</diffuse>
          <specular>0.5 0.5 0.5 1</specular>
        </material>
      </visual>
    </link>

    <!-- 前右轮 (FR) -->
    <link name="front_right_wheel">
      <pose>0.2 -0.205 0.075 1.5708 0 0</pose>
      <inertial>
        <mass>0.8</mass>
        <inertia>
          <ixx>0.012</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.012</iyy><iyz>0</iyz>
          <izz>0.02</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <cylinder><radius>0.075</radius><length>0.06</length></cylinder>
        </geometry>
        <surface>
          <friction>
            <ode><mu>1.0</mu><mu2>1.0</mu2></ode>
          </friction>
        </surface>
      </collision>
      <visual name="visual">
        <geometry>
          <cylinder><radius>0.075</radius><length>0.06</length></cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.15 0.15 0.15 1</diffuse>
          <specular>0.5 0.5 0.5 1</specular>
        </material>
      </visual>
    </link>

    <!-- 后左轮 (RL) -->
    <link name="rear_left_wheel">
      <pose>-0.2 0.205 0.075 1.5708 0 0</pose>
      <inertial>
        <mass>0.8</mass>
        <inertia>
          <ixx>0.012</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.012</iyy><iyz>0</iyz>
          <izz>0.02</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <cylinder><radius>0.075</radius><length>0.06</length></cylinder>
        </geometry>
        <surface>
          <friction>
            <ode><mu>1.0</mu><mu2>1.0</mu2></ode>
          </friction>
        </surface>
      </collision>
      <visual name="visual">
        <geometry>
          <cylinder><radius>0.075</radius><length>0.06</length></cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.15 0.15 0.15 1</diffuse>
          <specular>0.5 0.5 0.5 1</specular>
        </material>
      </visual>
    </link>

    <!-- 后右轮 (RR) -->
    <link name="rear_right_wheel">
      <pose>-0.2 -0.205 0.075 1.5708 0 0</pose>
      <inertial>
        <mass>0.8</mass>
        <inertia>
          <ixx>0.012</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.012</iyy><iyz>0</iyz>
          <izz>0.02</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <cylinder><radius>0.075</radius><length>0.06</length></cylinder>
        </geometry>
        <surface>
          <friction>
            <ode><mu>1.0</mu><mu2>1.0</mu2></ode>
          </friction>
        </surface>
      </collision>
      <visual name="visual">
        <geometry>
          <cylinder><radius>0.075</radius><length>0.06</length></cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.15 0.15 0.15 1</diffuse>
          <specular>0.5 0.5 0.5 1</specular>
        </material>
      </visual>
    </link>

    <!-- ==================== RGBD 深度相机 ==================== -->
    <link name="camera_link">
      <pose>0.25 0 0.28 0 0 0</pose>
      <inertial>
        <mass>0.2</mass>
        <inertia>
          <ixx>0.001</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.001</iyy><iyz>0</iyz>
          <izz>0.001</izz>
        </inertia>
      </inertial>

      <sensor name="rgbd_camera" type="depth">
        <camera name="camera">
          <horizontal_fov>1.047</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.1</near>
            <far>10.0</far>
          </clip>
        </camera>
        <always_on>true</always_on>
        <update_rate>30</update_rate>
        <plugin name="camera_controller" filename="libgazebo_ros_camera.so">
          <ros>
            <namespace>/camera_robot</namespace>
            <argument>image_raw:=rgb/image_raw</argument>
            <argument>camera_info:=rgb/camera_info</argument>
            <argument>depth/image_raw:=depth/image_raw</argument>
            <argument>depth/camera_info:=depth/camera_info</argument>
            <argument>points:=depth/points</argument>
          </ros>
          <camera_name>rgbd_camera</camera_name>
          <frame_name>camera_link</frame_name>
          <hack_baseline>0.07</hack_baseline>
          <min_depth>0.1</min_depth>
          <max_depth>10.0</max_depth>
        </plugin>
      </sensor>

      <visual name="visual">
        <geometry>
          <box><size>0.05 0.08 0.05</size></box>
        </geometry>
        <material>
          <ambient>0 0 1 1</ambient>
          <diffuse>0 0 1 1</diffuse>
        </material>
      </visual>
    </link>

    <!-- ==================== 激光雷达 ==================== -->
    <link name="lidar_link">
      <!-- 底盘顶面 z=0.13+0.075=0.205, 再加上雷达高度 0.025 -->
      <pose>0 0 0.23 0 0 0</pose>
      <inertial>
        <mass>0.1</mass>
        <inertia>
          <ixx>0.0001</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.0001</iyy><iyz>0</iyz>
          <izz>0.0001</izz>
        </inertia>
      </inertial>

      <collision name="collision">
        <geometry>
          <cylinder><radius>0.04</radius><length>0.05</length></cylinder>
        </geometry>
      </collision>
      <visual name="visual">
        <geometry>
          <cylinder><radius>0.04</radius><length>0.05</length></cylinder>
        </geometry>
        <material>
          <ambient>0.0 0.8 0.0 1</ambient>
          <diffuse>0.0 0.8 0.0 1</diffuse>
        </material>
      </visual>

      <sensor name="lidar" type="ray">
        <always_on>true</always_on>
        <update_rate>10</update_rate>
        <visualize>true</visualize>
        <ray>
          <scan>
            <horizontal>
              <samples>360</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159</min_angle>
              <max_angle>3.14159</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.15</min>
            <max>12.0</max>
            <resolution>0.01</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.01</stddev>
          </noise>
        </ray>
        <plugin name="lidar_controller" filename="libgazebo_ros_ray_sensor.so">
          <ros>
            <namespace>/camera_robot</namespace>
            <argument>~/out:=scan</argument>
          </ros>
          <output_type>sensor_msgs/LaserScan</output_type>
          <frame_name>lidar_link</frame_name>
        </plugin>
      </sensor>
    </link>

    <!-- ==================== 关节 ==================== -->

    <!-- 前左轮关节 -->
    <joint name="front_left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>front_left_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><effort>10</effort><velocity>100</velocity></limit>
        <dynamics><damping>0.1</damping><friction>0.1</friction></dynamics>
      </axis>
    </joint>

    <!-- 前右轮关节 -->
    <joint name="front_right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>front_right_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><effort>10</effort><velocity>100</velocity></limit>
        <dynamics><damping>0.1</damping><friction>0.1</friction></dynamics>
      </axis>
    </joint>

    <!-- 后左轮关节 -->
    <joint name="rear_left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>rear_left_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><effort>10</effort><velocity>100</velocity></limit>
        <dynamics><damping>0.1</damping><friction>0.1</friction></dynamics>
      </axis>
    </joint>

    <!-- 后右轮关节 -->
    <joint name="rear_right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>rear_right_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><effort>10</effort><velocity>100</velocity></limit>
        <dynamics><damping>0.1</damping><friction>0.1</friction></dynamics>
      </axis>
    </joint>

    <!-- 深度相机关节 -->
    <joint name="camera_joint" type="fixed">
      <parent>base_link</parent>
      <child>camera_link</child>
    </joint>

    <!-- 激光雷达关节 -->
    <joint name="lidar_joint" type="fixed">
      <parent>base_link</parent>
      <child>lidar_link</child>
    </joint>

    <!-- ==================== 差速驱动插件（四轮：左前+左后 / 右前+右后） ==================== -->
    <!--
      libgazebo_ros_diff_drive 支持多轮，通过分别设置两对轮子实现四轮差速。
      左侧驱动轮：front_left + rear_left
      右侧驱动轮：front_right + rear_right
    -->
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <namespace>/camera_robot</namespace>
      </ros>

      <!-- 四轮差速：必须声明轮对数量 -->
      <num_wheel_pairs>2</num_wheel_pairs>

      <!-- 左侧：前左 + 后左 -->
      <left_joint>front_left_wheel_joint</left_joint>
      <left_joint>rear_left_wheel_joint</left_joint>

      <!-- 右侧：前右 + 后右 -->
      <right_joint>front_right_wheel_joint</right_joint>
      <right_joint>rear_right_wheel_joint</right_joint>

      <wheel_separation>0.38</wheel_separation>
      <wheel_diameter>0.15</wheel_diameter>
      <max_wheel_torque>15</max_wheel_torque>
      <max_wheel_acceleration>5.0</max_wheel_acceleration>

      <command_topic>cmd_vel</command_topic>
      <odometry_topic>odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>

      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>
    </plugin>

  </model>
</sdf>
